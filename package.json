{
  "name": "mathpath-tutor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "tsx --test src/lib/*.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "deploy:test": "cdk deploy --app \"npx tsx infra/app.ts\" -c deploymentMode=testing",
    "deploy:prod": "cdk deploy --app \"npx tsx infra/app.ts\" -c deploymentMode=production",
    "destroy:test": "cdk destroy --app \"npx tsx infra/app.ts\" -c deploymentMode=testing"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1054.0",
    "@aws-sdk/client-ses": "^3.1054.0",
