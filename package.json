    "@types/react-dom": "^19",
    "@types/stripe": "^8.0.416",
    "@types/uuid": "^10.0.0",
    "aws-cdk": "^2.1129.0",
    "aws-cdk-lib": "^2.261.0",
    "constructs": "^10.6.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4",
