# Database (RDS in production)
DATABASE_URL="postgresql://mathpath:mathpath_dev@localhost:5432/mathpath_tutor"

# Authentication
JWT_SECRET="your-secret-key-here"

# AI Provider: "openai" or "bedrock"
AI_PROVIDER="bedrock"
AI_MODEL="us.anthropic.claude-sonnet-4-20250514"

# AWS Configuration (for Bedrock + other AWS services)
# Uses default credential chain: env vars → ~/.aws/credentials → IAM role
AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"

# OpenAI (alternative to Bedrock)
# AI_PROVIDER="openai"
# OPENAI_API_KEY="sk-your-openai-api-key-here"
# AI_MODEL="gpt-4o"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (SES)
SES_FROM_EMAIL="noreply@yourdomain.com"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PRICE_GROWTH_MONTHLY="price_xxx"
STRIPE_PRICE_GROWTH_YEARLY="price_xxx"
STRIPE_PRICE_FAMILY_MONTHLY="price_xxx"
STRIPE_PRICE_FAMILY_YEARLY="price_xxx"

# Internal API key for cron/scheduled notification tasks
INTERNAL_API_KEY="generate-a-secure-random-key"

# Demo Mode - set to "true" to run without database or AI
# Set to "false" for production
NEXT_PUBLIC_DEMO_MODE="true"
